{
  "name": "los-scf",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "turbo run migration:run --filter=api",
    "db:seed": "turbo run seed --filter=api"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
