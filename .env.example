# Application
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
JWT_SECRET=change-me-in-production-minimum-32-chars
JWT_EXPIRY=8h

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=los_scf
DB_USER=los_user
DB_PASSWORD=los_password
DB_SSL=false

# Redis / Queue
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Storage (S3 / MinIO)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minio_user
STORAGE_SECRET_KEY=minio_password
STORAGE_BUCKET=los-documents
STORAGE_REGION=ap-south-1
STORAGE_CDN_URL=

# AI — Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8192

# KYC — Karza (or Surepass / IDfy)
KARZA_BASE_URL=https://testapi.karza.in
KARZA_API_KEY=
KARZA_X_KARZA_KEY=

# Bank Statement Analysis — Perfios
PERFIOS_BASE_URL=https://developer.perfios.com
PERFIOS_CLIENT_ID=
PERFIOS_CLIENT_SECRET=
PERFIOS_INSTITUTION_ID=

# Bureau — CIBIL / Experian
CIBIL_BASE_URL=https://api.cibil.com
CIBIL_MEMBER_ID=
CIBIL_API_KEY=
EXPERIAN_BASE_URL=https://api.experian.com
EXPERIAN_API_KEY=

# eSign / eNACH — Digio
DIGIO_BASE_URL=https://ext.digio.in:444
DIGIO_CLIENT_ID=
DIGIO_CLIENT_SECRET=
DIGIO_WEBHOOK_SECRET=

# Payment / Disbursement — Razorpay X
RAZORPAYX_BASE_URL=https://api.razorpay.com/v1
RAZORPAYX_KEY_ID=
RAZORPAYX_KEY_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=

# Notifications
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@los-scf.com
SMS_PROVIDER=fast2sms
SMS_API_KEY=
WHATSAPP_PROVIDER=gupshup
WHATSAPP_API_KEY=
